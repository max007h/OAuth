```java
package com.poc.banking.service;

import com.poc.banking.dto.VirementRequest;
import com.poc.banking.dto.VirementResponse;
import com.poc.banking.entity.VirementEntity;
import com.poc.banking.repository.VirementRepository;
import com.poc.banking.util.JwtClaimsExtractor;
import lombok.RequiredArgsConstructor;
import org.springframework.http.HttpStatus;
import org.springframework.security.oauth2.jwt.Jwt;
import org.springframework.stereotype.Service;
import org.springframework.web.server.ResponseStatusException;

import java.time.LocalDateTime;
import java.util.List;
import java.util.Map;

@Service
@RequiredArgsConstructor
public class VirementService {

    private final VirementRepository repository;
    private final JwtClaimsExtractor extractor;

    // Effectuer un virement
    // Verifie que le body correspond aux authorization_details du token
    public VirementResponse effectuerVirement(VirementRequest request, Jwt jwt) {

        Map<String, Object> rar = extractor.getBankingTransfert(jwt);

        // Pas d'authorization_details dans le token - consentement manquant
        if (rar == null) {
            throw new ResponseStatusException(HttpStatus.FORBIDDEN,
                "Token sans authorization_details bankingTransfert");
        }

        // Verification que le body correspond au consentement donne
        String ibanToken  = (String) rar.get("iban");
        Number amountToken = (Number) rar.get("amount");

        if (!ibanToken.equals(request.getToIban())) {
            throw new ResponseStatusException(HttpStatus.FORBIDDEN,
                "IBAN ne correspond pas au consentement");
        }

        if (amountToken.doubleValue() != request.getAmount()) {
            throw new ResponseStatusException(HttpStatus.FORBIDDEN,
                "Montant ne correspond pas au consentement");
        }

        // Sauvegarde le virement en base
        VirementEntity entity = VirementEntity.builder()
            .fromIban(extractor.getIbanAccount(jwt))
            .toIban(request.getToIban())
            .amount(request.getAmount())
            .currency(request.getCurrency())
            .label(request.getLabel())
            .owner(extractor.getSub(jwt))
            .status("COMPLETED")
            .createdAt(LocalDateTime.now())
            .build();

        VirementEntity saved = repository.save(entity);
        return toResponse(saved);
    }

    // Mes virements uniquement - filtre par owner (sub du token)
    public List<VirementResponse> getMesVirements(Jwt jwt) {
        String owner = extractor.getSub(jwt);
        return repository.findByOwner(owner)
            .stream()
            .map(this::toResponse)
            .toList();
    }

    // Tous les virements - reserve aux APPROVERS
    public List<VirementResponse> getTousVirements(Jwt jwt) {
        if (!extractor.isApprover(jwt)) {
            throw new ResponseStatusException(HttpStatus.FORBIDDEN,
                "Acces reserve aux approbateurs");
        }
        return repository.findAll()
            .stream()
            .map(this::toResponse)
            .toList();
    }

    // Convertit une entite en DTO de reponse
    private VirementResponse toResponse(VirementEntity e) {
        return VirementResponse.builder()
            .id(e.getId())
            .fromIban(e.getFromIban())
            .toIban(e.getToIban())
            .amount(e.getAmount())
            .currency(e.getCurrency())
            .label(e.getLabel())
            .owner(e.getOwner())
            .status(e.getStatus())
            .createdAt(e.getCreatedAt())
            .build();
    }
}
