## `src/main/java/com/poc/banking/util/JwtClaimsExtractor.java`

```java
package com.poc.banking.util;

import org.springframework.security.oauth2.jwt.Jwt;
import org.springframework.stereotype.Component;

import java.util.List;
import java.util.Map;

@Component
public class JwtClaimsExtractor {

    // Retourne l'IBAN du compte de l'utilisateur connecte
    public String getIbanAccount(Jwt jwt) {
        return jwt.getClaimAsString("ibanAccount");
    }

    // Retourne le sub (identifiant unique) de l'utilisateur
    public String getSub(Jwt jwt) {
        return jwt.getSubject();
    }

    // Retourne les authorization_details du token
    public List<Map<String, Object>> getAuthorizationDetails(Jwt jwt) {
        return jwt.getClaim("authorization_details");
    }

    // Retourne le premier authorization_details de type bankingTransfert
    public Map<String, Object> getBankingTransfert(Jwt jwt) {
        List<Map<String, Object>> details = getAuthorizationDetails(jwt);
        if (details == null || details.isEmpty()) return null;

        return details.stream()
            .filter(d -> "bankingTransfert".equals(d.get("type")))
            .findFirst()
            .orElse(null);
    }

    // Verifie si l'utilisateur est dans le groupe APPROVERS
    public boolean isApprover(Jwt jwt) {
        List<String> groups = jwt.getClaim("isMemberOf");
        if (groups == null) return false;
        return groups.stream().anyMatch(g -> g.contains("APPROVERS"));
    }
}
